module();

###
Ascii.zn - small ASCII character helpers.
###

func bool is_space(int c) {
    return c == 32 || c == 9 || c == 10 || c == 13;
}

func bool is_alpha(int c) {
    return (c >= 65 && c <= 90) || (c >= 97 && c <= 122) || c == 95;
}

func bool is_digit(int c) {
    return c >= 48 && c <= 57;
}

